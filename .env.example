# OpenRouter API 키 (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Groq API 키 (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Hugging Face API 토큰 — 이미지 생성 (FLUX.1-schnell)
# 발급: https://huggingface.co/settings/tokens  (무료 계정 가능)
HF_TOKEN=your_huggingface_token_here

# Supabase 설정 (https://supabase.com/dashboard)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
